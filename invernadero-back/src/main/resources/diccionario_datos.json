{
  "proyecto": "Smart Greenhouse — Invernadero Inteligente",
  "version": "1.0.0",
  "motor": "PostgreSQL 15",
  "descripcion": "Diccionario de datos del sistema. Define las tablas, columnas, tipos, restricciones y enumeraciones del modelo relacional.",
  "tablas": [
    {
      "nombre": "zonas",
      "descripcion": "Espacio físico o lógico del invernadero. Es el agregado raíz del modelo: agrupa cultivos, lecturas y umbrales.",
      "clase_entidad": "com.tomasrojas.invernadero.model.entity.ZonaEntity",
      "clase_dominio": "com.tomasrojas.invernadero.model.Zona",
      "columnas": [
        {
          "nombre": "id",
          "tipo_sql": "UUID",
          "tipo_java": "java.util.UUID",
          "nullable": false,
          "clave_primaria": true,
          "clave_foranea": false,
          "generacion": "AUTO (GenerationType.UUID)",
          "descripcion": "Identificador único de la zona, generado automáticamente por la base de datos."
        },
        {
          "nombre": "nombre",
          "tipo_sql": "VARCHAR(120)",
          "tipo_java": "String",
          "nullable": false,
          "clave_primaria": false,
          "clave_foranea": false,
          "validacion": "@NotBlank, @Size(max=120)",
          "descripcion": "Nombre descriptivo de la zona. Obligatorio, máximo 120 caracteres."
        },
        {
          "nombre": "descripcion",
          "tipo_sql": "VARCHAR(2000)",
          "tipo_java": "String",
          "nullable": true,
          "clave_primaria": false,
          "clave_foranea": false,
          "validacion": "@Size(max=2000)",
          "descripcion": "Descripción detallada del propósito o características de la zona. Opcional."
        },
        {
          "nombre": "ubicacion",
          "tipo_sql": "VARCHAR(200)",
          "tipo_java": "String",
          "nullable": true,
          "clave_primaria": false,
          "clave_foranea": false,
          "validacion": "@Size(max=200)",
          "descripcion": "Ubicación física dentro del invernadero. Opcional."
        },
        {
          "nombre": "tipo",
          "tipo_sql": "VARCHAR(20)",
          "tipo_java": "com.tomasrojas.invernadero.model.TipoZona",
          "nullable": true,
          "clave_primaria": false,
          "clave_foranea": false,
          "enum": "TipoZona",
          "descripcion": "Tipo de infraestructura de la zona. Almacenado como texto (EnumType.STRING). Opcional."
        },
        {
          "nombre": "aream2",
          "tipo_sql": "NUMERIC(8,2)",
          "tipo_java": "java.math.BigDecimal",
          "nullable": true,
          "clave_primaria": false,
          "clave_foranea": false,
          "descripcion": "Área de la zona en metros cuadrados. Precisión de 8 dígitos con 2 decimales. Opcional."
        },
        {
          "nombre": "creado_en",
          "tipo_sql": "TIMESTAMP WITH TIME ZONE",
          "tipo_java": "java.time.Instant",
          "nullable": false,
          "clave_primaria": false,
          "clave_foranea": false,
          "generacion": "@PrePersist — asignado automáticamente al insertar",
          "descripcion": "Marca de tiempo UTC de creación del registro. No se puede actualizar."
        }
      ]
    },
    {
      "nombre": "cultivos",
      "descripcion": "Planta o cultivo registrado dentro de una zona. Tiene un ciclo de vida con estado (activo, cosechado, etc.).",
      "clase_entidad": "com.tomasrojas.invernadero.model.entity.CultivoEntity",
      "clase_dominio": "com.tomasrojas.invernadero.model.Cultivo",
      "columnas": [
        {
          "nombre": "id",
          "tipo_sql": "UUID",
          "tipo_java": "java.util.UUID",
          "nullable": false,
          "clave_primaria": true,
          "clave_foranea": false,
          "generacion": "AUTO (GenerationType.UUID)",
          "descripcion": "Identificador único del cultivo."
        },
        {
          "nombre": "zona_id",
          "tipo_sql": "UUID",
          "tipo_java": "java.util.UUID",
          "nullable": false,
          "clave_primaria": false,
