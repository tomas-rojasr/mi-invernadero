        },
        {
          "nombre": "variedad",
          "tipo_sql": "VARCHAR(120)",
          "tipo_java": "String",
          "nullable": true,
          "clave_primaria": false,
          "clave_foranea": false,
          "validacion": "@Size(max=120)",
          "descripcion": "Variedad específica del cultivo (ej. Batavia, Cherry). Opcional."
        },
        {
          "nombre": "notas",
          "tipo_sql": "VARCHAR(2000)",
          "tipo_java": "String",
          "nullable": true,
          "clave_primaria": false,
          "clave_foranea": false,
          "validacion": "@Size(max=2000)",
          "descripcion": "Notas de seguimiento o cuidados especiales. Opcional."
        },
        {
          "nombre": "plantado_en",
          "tipo_sql": "TIMESTAMP WITH TIME ZONE",
          "tipo_java": "java.time.Instant",
          "nullable": true,
          "clave_primaria": false,
          "clave_foranea": false,
          "descripcion": "Fecha y hora de siembra en UTC. Opcional."
        },
        {
          "nombre": "fecha_cosecha_estimada",
          "tipo_sql": "TIMESTAMP WITH TIME ZONE",
          "tipo_java": "java.time.Instant",
          "nullable": true,
          "clave_primaria": false,
          "clave_foranea": false,
          "descripcion": "Fecha estimada de cosecha en UTC. Opcional."
        },
        {
          "nombre": "area_m2",
          "tipo_sql": "NUMERIC(8,2)",
          "tipo_java": "java.math.BigDecimal",
          "nullable": true,
          "clave_primaria": false,
          "clave_foranea": false,
          "descripcion": "Área sembrada en metros cuadrados. Opcional."
        },
        {
          "nombre": "cantidad_sembrada",
          "tipo_sql": "INTEGER",
          "tipo_java": "Integer",
          "nullable": true,
          "clave_primaria": false,
          "clave_foranea": false,
          "descripcion": "Cantidad de unidades o plantas sembradas. Opcional."
        },
        {
          "nombre": "rendimiento_esperado_kg",
          "tipo_sql": "NUMERIC(8,2)",
          "tipo_java": "java.math.BigDecimal",
          "nullable": true,
          "clave_primaria": false,
          "clave_foranea": false,
          "descripcion": "Rendimiento esperado de la cosecha en kilogramos. Opcional."
        },
        {
          "nombre": "estado",
          "tipo_sql": "VARCHAR(20)",
          "tipo_java": "com.tomasrojas.invernadero.model.EstadoCultivo",
          "nullable": true,
          "clave_primaria": false,
          "clave_foranea": false,
          "enum": "EstadoCultivo",
          "descripcion": "Estado del ciclo de vida del cultivo. Almacenado como texto. Opcional."
        },
        {
          "nombre": "creado_en",
          "tipo_sql": "TIMESTAMP WITH TIME ZONE",
          "tipo_java": "java.time.Instant",
          "nullable": false,
          "clave_primaria": false,
          "clave_foranea": false,
          "generacion": "@PrePersist — asignado automáticamente al insertar",
          "descripcion": "Marca de tiempo UTC de registro en el sistema. No se puede actualizar."
        }
      ]
    },
    {
      "nombre": "lecturas_ambientales",
      "descripcion": "Medición ambiental puntual registrada en una zona. Puede provenir de un sensor automático o de entrada manual.",
      "clase_entidad": "com.tomasrojas.invernadero.model.entity.LecturaEntity",
      "clase_dominio": "com.tomasrojas.invernadero.model.LecturaAmbiental",
      "columnas": [
        {
          "nombre": "id",
          "tipo_sql": "UUID",
          "tipo_java": "java.util.UUID",
          "nullable": false,
          "clave_primaria": true,
          "clave_foranea": false,
          "generacion": "AUTO (GenerationType.UUID)",
          "descripcion": "Identificador único de la lectura."
        },
        {
          "nombre": "zona_id",
          "tipo_sql": "UUID",
          "tipo_java": "java.util.UUID",
          "nullable": false,
          "clave_primaria": false,
          "clave_foranea": true,
          "referencia": "zonas(id)",
          "descripcion": "Clave foránea hacia la zona donde se tomó la medición. Relación N:1."
        },
        {
