          "nullable": false,
          "clave_primaria": false,
          "clave_foranea": false,
          "descripcion": "Valor numérico de la medición. Obligatorio."
        },
        {
          "nombre": "fuente",
          "tipo_sql": "VARCHAR(20)",
          "tipo_java": "com.tomasrojas.invernadero.model.FuenteLectura",
          "nullable": false,
          "clave_primaria": false,
          "clave_foranea": false,
          "enum": "FuenteLectura",
          "descripcion": "Origen del dato: ingreso manual o sensor automático. Obligatorio."
        },
        {
          "nombre": "notas",
          "tipo_sql": "VARCHAR(500)",
          "tipo_java": "String",
          "nullable": true,
          "clave_primaria": false,
          "clave_foranea": false,
          "descripcion": "Observaciones adicionales sobre la lectura. Opcional."
        },
        {
          "nombre": "registrado_en",
          "tipo_sql": "TIMESTAMP WITH TIME ZONE",
          "tipo_java": "java.time.Instant",
          "nullable": false,
          "clave_primaria": false,
          "clave_foranea": false,
          "generacion": "@PrePersist — asignado automáticamente al insertar",
          "descripcion": "Marca de tiempo UTC de registro. Usado para ordenar lecturas de más reciente a más antigua."
        }
      ]
    },
    {
      "nombre": "umbrales_ambientales",
      "descripcion": "Rango mínimo y máximo aceptable para una métrica ambiental en una zona. Una zona tiene como máximo un umbral por tipo de métrica (upsert).",
      "clase_entidad": "com.tomasrojas.invernadero.model.entity.UmbralEntity",
      "clase_dominio": "com.tomasrojas.invernadero.model.UmbralAmbiental",
      "columnas": [
        {
          "nombre": "id",
          "tipo_sql": "UUID",
          "tipo_java": "java.util.UUID",
          "nullable": false,
          "clave_primaria": true,
          "clave_foranea": false,
          "generacion": "AUTO (GenerationType.UUID)",
          "descripcion": "Identificador único del umbral."
