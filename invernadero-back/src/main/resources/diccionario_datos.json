        {
          "nombre": "zona_id",
          "tipo_sql": "UUID",
          "tipo_java": "java.util.UUID",
          "nullable": false,
          "clave_primaria": false,
          "clave_foranea": true,
          "referencia": "zonas(id)",
          "descripcion": "Clave foránea hacia la zona a la que aplica el umbral. Relación N:1."
        },
        {
          "nombre": "tipo",
          "tipo_sql": "VARCHAR(30)",
          "tipo_java": "com.tomasrojas.invernadero.model.MetricaTipo",
          "nullable": false,
          "clave_primaria": false,
          "clave_foranea": false,
          "enum": "MetricaTipo",
          "descripcion": "Tipo de métrica al que aplica el umbral. Obligatorio."
