        {
          "nombre": "valor_min",
          "tipo_sql": "NUMERIC(8,2)",
          "tipo_java": "java.math.BigDecimal",
          "nullable": false,
          "clave_primaria": false,
          "clave_foranea": false,
          "descripcion": "Valor mínimo aceptable para la métrica. Obligatorio."
        },
        {
          "nombre": "valor_max",
          "tipo_sql": "NUMERIC(8,2)",
          "tipo_java": "java.math.BigDecimal",
          "nullable": false,
          "clave_primaria": false,
          "clave_foranea": false,
          "descripcion": "Valor máximo aceptable para la métrica. Obligatorio."
        },
        {
          "nombre": "actualizado_en",
          "tipo_sql": "TIMESTAMP WITH TIME ZONE",
          "tipo_java": "java.time.Instant",
          "nullable": false,
          "clave_primaria": false,
          "clave_foranea": false,
          "generacion": "@PrePersist / @PreUpdate — actualizado automáticamente",
          "descripcion": "Marca de tiempo UTC de la última actualización del umbral."
