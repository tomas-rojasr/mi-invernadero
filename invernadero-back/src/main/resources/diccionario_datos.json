  ],
  "enumeraciones": [
    {
      "nombre": "TipoZona",
      "clase": "com.tomasrojas.invernadero.model.TipoZona",
      "descripcion": "Tipo de infraestructura física de la zona del invernadero.",
      "valores": [
        { "valor": "INVERNADERO",   "descripcion": "Estructura cerrada con control climático." },
        { "valor": "CAMPO_ABIERTO", "descripcion": "Zona expuesta al exterior sin cubierta." },
        { "valor": "HIDROPONICO",   "descripcion": "Sistema de cultivo sin suelo en solución nutritiva." },
        { "valor": "MACETAS",       "descripcion": "Cultivo en recipientes individuales." }
      ]
    },
    {
      "nombre": "EstadoCultivo",
      "clase": "com.tomasrojas.invernadero.model.EstadoCultivo",
      "descripcion": "Estado del ciclo de vida de un cultivo registrado en el sistema.",
      "valores": [
        { "valor": "ACTIVO",         "descripcion": "Cultivo en crecimiento normal." },
        { "valor": "EN_PREPARACION", "descripcion": "Zona o sustrato en preparación antes de la siembra." },
        { "valor": "COSECHADO",      "descripcion": "Cultivo que completó su ciclo y fue cosechado." },
        { "valor": "PERDIDO",        "descripcion": "Cultivo que no prosperó por enfermedad, plaga u otro factor." }
      ]
    },
    {
      "nombre": "MetricaTipo",
      "clase": "com.tomasrojas.invernadero.model.MetricaTipo",
      "descripcion": "Tipo de variable ambiental que puede ser medida o controlada en una zona.",
      "valores": [
        { "valor": "TEMPERATURA_C",          "descripcion": "Temperatura del aire en grados Celsius." },
        { "valor": "HUMEDAD_RELATIVA_PCT",   "descripcion": "Humedad relativa del aire en porcentaje (0-100)." },
        { "valor": "LUZ_LUX",               "descripcion": "Intensidad luminosa en lux." },
        { "valor": "HUMEDAD_SUELO_PCT",      "descripcion": "Humedad del suelo en porcentaje volumétrico (0-100)." }
      ]
    },
    {
      "nombre": "FuenteLectura",
      "clase": "com.tomasrojas.invernadero.model.FuenteLectura",
      "descripcion": "Origen del dato de una lectura ambiental registrada en el sistema.",
      "valores": [
        { "valor": "MANUAL",           "descripcion": "Valor ingresado manualmente por el usuario." },
        { "valor": "SENSOR_AUTOMATICO","descripcion": "Valor capturado automáticamente por un sensor IoT." }
      ]
    }
  ],
  "relaciones": [
    {
      "desde": "cultivos.zona_id",
      "hacia": "zonas.id",
      "tipo": "N:1",
      "descripcion": "Un cultivo pertenece a exactamente una zona. Una zona puede tener múltiples cultivos."
    },
    {
      "desde": "lecturas_ambientales.zona_id",
      "hacia": "zonas.id",
      "tipo": "N:1",
      "descripcion": "Una lectura pertenece a exactamente una zona. Una zona puede tener múltiples lecturas."
    },
    {
      "desde": "umbrales_ambientales.zona_id",
      "hacia": "zonas.id",
      "tipo": "N:1",
      "descripcion": "Un umbral pertenece a exactamente una zona. Una zona puede tener múltiples umbrales (uno por tipo de métrica)."
    }
  ]
}
